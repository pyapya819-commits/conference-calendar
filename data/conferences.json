# 13. 메디칼허브 월별 학술대회 (CV + Pain 통합 소스)
# =====================
def crawl_healthmedia():
    print("📡 메디칼허브 크롤링...")
    results = []

    cv_kw = ['고혈압', '심장', '심혈관', '당뇨', '내분비', '신장', '지질', '동맥경화',
             '심부전', '내과', 'TCTAP', '대사', '비만', '갑상선', '골다공증', '골대사',
             'SICEM', '부정맥', '심근경색', '뇌혈관', '심뇌혈관', '혈압', '순환기',
             '심혈관중재', '심초음파', '이상지질', '심장대사']
    pain_kw = ['정형외과', '신경외과', '마취', '통증', '재활', '척추', '관절',
               '신경과', '두통', '뇌졸중', '신경', '근골격', '류마티스']
    exclude_kw = ['피부', '안과', '이비인후', '산부인과', '소아', '치과', '한의',
                  '정신', '흉부외과', '비뇨', '성형', '방사선', '병리',
                  '종양', '혈액', '폐암', '위암', '간학', '감염', '소화기']

    # 자동 검색으로 새 기사 찾기
    search_url = (f'http://www.healthmedia.co.kr/news/articleList.html'
                  f'?sc_section_code=S1N5&sc_sub_section_code=S2N30'
                  f'&view_type=sm&sc_word={CURRENT_YEAR}%EB%85%84')
    soup = get_soup(search_url)
    article_urls = []

    if soup:
        for a in soup.select('a[href*="articleView"]'):
            href = a.get('href', '')
            title = a.get_text(strip=True)
            if str(CURRENT_YEAR) in title and ('학술일정' in title or '국내' in title):
                if not href.startswith('http'):
                    href = 'http://www.healthmedia.co.kr' + href
                if href not in article_urls:
                    article_urls.append(href)

    # 알려진 URL 보완 (5월 추가, 7월 추가)
    known_urls = [
        'http://www.healthmedia.co.kr/news/articleView.html?idxno=104741',  # 3월
        'http://www.healthmedia.co.kr/news/articleView.html?idxno=104995',  # 4월
        'http://www.healthmedia.co.kr/news/articleView.html?idxno=105283',  # 5월
        'http://www.healthmedia.co.kr/news/articleView.html?idxno=105605',  # 6월
        'http://www.healthmedia.co.kr/news/articleView.html?idxno=106062',  # 7월
    ]
    for u in known_urls:
        if u not in article_urls:
            article_urls.append(u)

    seen = set()
    for url in article_urls:
        time.sleep(DELAY)
        detail = get_soup(url)
        if not detail:
            continue

        content = detail.get_text(separator='\n', strip=True)
        lines = content.split('\n')

        for line in lines:
            line = line.strip()
            date_match = re.match(rf'({CURRENT_YEAR}-\d{{2}}-\d{{2}})\s+(.+)', line)
            if not date_match:
                continue

            date_str = date_match.group(1)
            rest = date_match.group(2).strip()

            if any(ex in rest for ex in exclude_kw):
                continue

            is_cv = any(k in rest for k in cv_kw)
            is_pain = any(k in rest for k in pain_kw)
            if not is_cv and not is_pain:
                continue

            # 이름/주관/장소 분리
            parts = re.split(r'\s{2,}', rest)
            name = parts[0].strip() if parts else rest[:80]
            location = parts[-1].strip() if len(parts) >= 3 else (
                parts[1].strip() if len(parts) == 2 else '장소 미정')

            if not name or len(name) < 3:
                continue

            key = (name[:20], date_str)
            if key in seen:
                continue
            seen.add(key)

            category = 'cv' if is_cv else 'pain'
            intl_list = ['국제', 'International', 'TCTAP', 'World', 'SICEM', 'Asia']
            event_type = 'intl' if any(k in name for k in intl_list) else 'domestic'

            ev = make_event(name, date_str, date_str, location, category, event_type, '메디칼허브', url)
            if ev:
                results.append(ev)
                print(f"  ✅ {ev['name']} ({date_str})")

    print(f"  → {len(results)}건 수집")
    return results

