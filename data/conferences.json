# 12. 대한정형외과학회 연중행사 (Pain - OS)
# =====================
def crawl_koa_schedule():
    print("📡 대한정형외과학회 크롤링...")
    results = []

    # 연중행사 페이지 시도
    for year in [CURRENT_YEAR, CURRENT_YEAR + 1]:
        soup = get_soup(f'https://www.koa.or.kr/schedule/?year={year}')
        if not soup:
            continue

        text = soup.get_text(separator='\n', strip=True)
        lines = text.split('\n')

        for line in lines:
            line = line.strip()
            if not line or len(line) < 5:
                continue

            date_match = re.search(r'(\d{4})[.\-년](\d{1,2})[.\-월](\d{1,2})', line)
            if not date_match:
                continue
            y, mo, d = date_match.groups()
            if int(y) < CURRENT_YEAR:
                continue

            start = f"{int(y):04d}-{int(mo):02d}-{int(d):02d}"
            end_match = re.search(r'~\s*(\d{4})?[.\-]?(\d{1,2})[.\-](\d{1,2})', line)
            end = start
            if end_match:
                ey = end_match.group(1) or y
                end = f"{int(ey):04d}-{int(end_match.group(2)):02d}-{int(end_match.group(3)):02d}"

            name = re.sub(r'\d{4}[.\-년]\d{1,2}[.\-월]\d{1,2}[.\-일]?\s*(?:~.+?)?\s*', '', line).strip()
            if not name or len(name) < 3:
                continue

            intl_kw = ['국제', 'International', 'AAOS', 'APOA', 'World', 'COA']
            event_type = 'intl' if any(k in name for k in intl_kw) else 'domestic'

            ev = make_event(name, start, end, '장소 미정', 'pain', event_type,
                           '대한정형외과학회', f'https://www.koa.or.kr/schedule/?year={year}')
            if ev:
                results.append(ev)
                print(f"  ✅ {ev['name']} ({start})")

        time.sleep(DELAY)

    print(f"  → {len(results)}건 수집")
    return results

