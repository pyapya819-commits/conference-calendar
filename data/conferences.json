def crawl_kaim():
    print("📡 대한내과학회 연수교육 크롤링...")
    results = []
    cv_kw = ['순환기', '심장', '심혈관', '고혈압', '당뇨', '내분비', '신장', '지질',
             '동맥경화', '심부전', '부정맥', '대사', '갑상선', '골다공증', '골대사',
             '혈압', 'TCTAP', 'KSN', 'SICEM', '심근경색', '뇌혈관', '심뇌혈관']
    pain_kw = ['신경', '통증', '척추', '관절', '류마티스', '두통', '재활']
    exclude_kw = ['소화기', '호흡기', '혈액', '종양', '감염', '알레르기면역',
                  '비뇨', '피부', '안과', '이비인후', '정신', '성형', '간',
                  '폐', '위', '대장', '췌']

    urls = [
        f'https://www.kaim.or.kr/mobile/schedule/edu_list.php?gubun=1&main_num=2',
        f'https://www.kaim.or.kr/mobile/schedule/edu_list.php?gubun=2&main_num=2',
    ]

    seen = set()
    for url in urls:
        soup = get_soup(url)
        if not soup:
            continue

        text = soup.get_text(separator='\n', strip=True)
        lines = text.split('\n')

        for line in lines:
            line = line.strip()
            if not line:
                continue

            # "2026년 X월 X일(X)" 패턴 찾기
            date_match = re.search(r'(\d{4})년\s*(\d{1,2})월\s*(\d{1,2})일', line)
            if not date_match:
                continue

            y, mo, d = date_match.groups()
            if int(y) != CURRENT_YEAR:
                continue

            start = f"{int(y):04d}-{int(mo):02d}-{int(d):02d}"

            # 제외 키워드 체크
            if any(ex in line for ex in exclude_kw):
                continue

            # CV/Pain 분류
            is_cv = any(k in line for k in cv_kw)
            is_pain = any(k in line for k in pain_kw)
            if not is_cv and not is_pain:
                continue

            # 이름 추출: "접수 [오프라인] 학회명 2026년..." 패턴
            name_match = re.search(r'(?:접수|승인)\s*\[.+?\]\s*(.+?)\s*\d{4}년', line)
            if name_match:
                name = name_match.group(1).strip()
            else:
                # 날짜 이전 텍스트
                idx = line.find(f'{y}년')
                name = line[:idx].strip() if idx > 0 else line[:60]
                name = re.sub(r'^(접수|승인)\s*\[.+?\]\s*', '', name).strip()

            if not name or len(name) < 3:
                continue

            key = (name[:20], start)
            if key in seen:
                continue
            seen.add(key)

            # 장소 추출
            loc_match = re.search(r'\d{4}년.+?\d{1,2}:\d{2}\s+(.+?)(?:\s+평점|\s*$)', line)
            location = loc_match.group(1).strip() if loc_match else '장소 미정'

            category = 'cv' if is_cv else 'pain'
            ev = make_event(name, start, start, location, category, 'domestic', '대한내과학회', url)
            if ev:
                results.append(ev)
                print(f"  ✅ {ev['name']} ({start})")

        time.sleep(DELAY)

    print(f"  → {len(results)}건 수집")
    return results

